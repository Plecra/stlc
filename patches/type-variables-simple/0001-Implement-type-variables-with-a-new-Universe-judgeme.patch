 demo/Cargo.toml        |  3 +-
 demo/src/main.rs       | 10 +++----
 derivations/src/lib.rs | 64 +++++++++++++++++++++++++++++++-----------
 kernel/src/lib.rs      | 62 ++++++++++++++++++++++++++++++++--------
 5 files changed, 105 insertions(+), 35 deletions(-)

