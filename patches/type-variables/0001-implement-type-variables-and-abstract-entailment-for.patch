 use std::collections::HashMap;
 #[derive(Debug)]
-pub struct ContextIndex(HashMap<String, core::Type>);
+enum BindingProof {
+    Var(kernel::UnivProof),
+    TypeVar,
+}
+impl BindingProof {
+    fn as_var(&self) -> Option<&kernel::UnivProof> {
+        match self {
+            BindingProof::Var(p) => Some(p),
+            BindingProof::TypeVar => None,
+        }
+    }
+    fn matches_binding(&self, binding: &kernel::Binding) -> bool {
+        match (self, binding) {
+            (BindingProof::Var(p), kernel::Binding::Var(ty)) => p.get().concl.ty == *ty,
+            (BindingProof::TypeVar, kernel::Binding::TypeVar) => true,
+            _ => false,
+        }
+    }
+}
+#[derive(Debug)]
+pub struct ContextIndex(HashMap<String, BindingProof>);
+
+fn verify_ty(ty: &core::Type) -> kernel::UnivProof {
+    match ty {
+        core::Type::Var(name) => kernel::Proof::type_var(name.clone()),
+        core::Type::Arrow(a, b) => func(verify_ty(a), verify_ty(b)),
+    }
+}
+fn compatible_cx(index: &ContextIndex, cx: &[(String, kernel::Binding)]) -> bool {
+    cx.iter().all(|(n, b)| index.0.get(n).is_some_and(|bp| bp.matches_binding(b)))
+}
 impl ContextIndex {
-    pub fn new(binds: impl Iterator<Item = (String, core::Type)>) -> Self {
-        ContextIndex(binds.collect())
+    pub fn new(binds: impl Iterator<Item = (String, kernel::Binding)>) -> Result<Self, Error> {
+        let mut this = ContextIndex(HashMap::new());
+        for (n, bind) in binds {
+            match bind {
+                kernel::Binding::TypeVar => {
+                    if this.0.insert(n, BindingProof::TypeVar).is_some() {
+                        return Err(Error(()));
+                    }
+                }
+                kernel::Binding::Var(ty) => {
+                    let univ = verify_ty(&ty);
+                    if !compatible_cx(&this, &univ.get().context) || this.0.insert(n, BindingProof::Var(univ)).is_some() {
+                        return Err(Error(()));
+                    }
+                }
+            }
+        }
+        Ok(this)
     }
 }
