+/// [`kernel::Proof::func`] with automatic merging of the contexts of the function and argument.
+pub fn func(f: kernel::UnivProof, a: kernel::UnivProof) -> kernel::UnivProof {
+    let mut cx = vec![];
+    let mut present = std::collections::HashSet::new();
+    for (s, t) in f.get().context.iter().chain(&a.get().context) {
+        if present.insert(s) {
